<!DOCTYPE html>
<html>
<head>
    <title>Users</title>
</head>
<body>

<h1>User List</h1>

<a href="/users/create">Add User</a>

<table border="1" cellpadding="10">

    <tr>
        <th>ID</th>
        <th>Name</th>
        <th>Email</th>
        <th>Action</th>
    </tr>

    <% users.forEach(user => { %>

    <tr>
        <td><%= user.id %></td>
        <td><%= user.name %></td>
        <td><%= user.email %></td>

        <td>
            <a href="/users/edit/<%= user.id %>">
                Edit
            </a>

            <a href="/users/delete/<%= user.id %>">
                Delete
            </a>
        </td>
    </tr>

    <% }) %>

</table>

</body>
</html>