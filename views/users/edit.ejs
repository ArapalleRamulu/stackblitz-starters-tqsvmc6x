<!DOCTYPE html>
<html>
<head>
    <title>Edit User</title>
</head>
<body>

<h1>Edit User</h1>

<form
    action="/users/update/<%= user.id %>"
    method="POST"
>

    <input
        type="text"
        name="name"
        value="<%= user.name %>"
    >

    <br><br>

    <input
        type="email"
        name="email"
        value="<%= user.email %>"
    >

    <br><br>

    <button type="submit">
        Update User
    </button>

</form>

</body>
</html>